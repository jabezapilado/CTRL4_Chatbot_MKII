CHATBOT_DB_HOST=127.0.0.1
# If your MySQL server uses a different port in your DB client, put it here.
CHATBOT_DB_PORT=3308
CHATBOT_DB_USER=root
CHATBOT_DB_PASSWORD=
CHATBOT_DB_NAME=soc_chatbot
CHATBOT_DB_CHARSET=utf8mb4
CHATBOT_DB_SSL_CA=
CHATBOT_DB_SSL_VERIFY_CERT=false
CHATBOT_DEBUG=true
CHATBOT_SECRET_KEY=change-this-in-production
CHATBOT_PORT=5000

# Optional account seeding for first-time setup.
# Leave blank to skip automatic account creation.
CHATBOT_SEED_STUDENT_EMAIL=student@hau.edu.ph
CHATBOT_SEED_STUDENT_NAME=Maria Santos
CHATBOT_SEED_STUDENT_PASSWORD=student123

CHATBOT_SEED_STAFF_EMAIL=staff@hau.edu.ph
CHATBOT_SEED_STAFF_NAME=Ms. Reyes
CHATBOT_SEED_STAFF_PASSWORD=staff123

CHATBOT_SEED_ADMIN_EMAIL=admin@hau.edu.ph
CHATBOT_SEED_ADMIN_NAME=System Admin
CHATBOT_SEED_ADMIN_PASSWORD=admin123

# Multilingual RAG settings
CHATBOT_RAG_DOCS_DIR=knowledge_base
CHATBOT_RAG_INDEX_DIR=data/rag_index
CHATBOT_RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-large
CHATBOT_RAG_TOP_K=5
CHATBOT_RAG_MIN_SCORE=0.30
CHATBOT_RAG_CHUNK_SIZE=700
CHATBOT_RAG_CHUNK_OVERLAP=120
CHATBOT_RAG_AUTO_BUILD_ON_START=true
CHATBOT_RAG_GENERATOR_MODEL=

# Emotion-based escalation settings
CHATBOT_EMOTION_ESCALATION_ENABLED=true
CHATBOT_EMOTION_ESCALATION_THRESHOLD=0.55